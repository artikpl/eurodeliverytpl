{% extends "logged.twig" %}
{% block breadcrumbs %}<a href="/">Strona główna</a> &gt; <a href="/panel-klienta">Panel klienta</a> &gt; <a href="/kontakty">Książka adresowa</a>{% endblock %}
{% block header %}Książka adresowa{% endblock %}
{% block title %}Książka adresowa{% endblock %}
{% block inner %}

    <div class="mb-1">
         <form>
            <label>
                Fraza
                <input type="text" name="query" value="{{ data.query }}" style="width: 20em; display: inline;">
                <button type="submit">Wyszukaj</button>
            </label>
         </form>
    </div>
    <div class="row mb-1">
        <div class="col">
            <a href="/kontakty/nowy" class="btn">Dodaj adres</a>
        </div>
    </div>
    {% if empty(data.rows) %}
    <h2>Brak adresów</h2>
    {% else %}
        <div class="table-details-wrapper">
            <table class="table-details">
                <thead>
                    <tr>
                        <th>Nazwa</th>
                        <th>Nazwisko, Imię, Firma<br>Kraj, Miasto, Adres</th>
                        <th>Telefon</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for row in data.rows %}
                <tr>
                    <td>{{row.name}}</td>
                    <td>
                        {{row.lastname}} {{row.firstname}} {{row.company}}<br />
                        {{ row.country.iso }}, {{ row.city}}, {{ row.street}} {{ row.building}} {% if isset(row.apartment) %}/{{ row.apartment }}{% endif %}
                    </td>
                    <td >{{ row.phone }}</td>
                    <td >
                        <a href="/kontakty/wyslij/{{ row.id }}" id="adres{{ row.id }}" class="wyslijPaczke">Wybierz</a><br />
                        <a href="/kontakty/{{ row.id }}">Edycja</a> /
                        <a href="/kontakty/usun/{{ row.id }}" onclick="if (confirm(&quot;Czy na pewno chcesz usun\u0105\u0107 ten adres?&quot;)) { return true; } return false;">Usuń</a>
                    </td>
                </tr>
                {% endfor %}
                </tbody>
        </table>
        </div>
    {% endif %}
{% endblock %}