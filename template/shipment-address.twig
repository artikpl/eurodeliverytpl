<div class="col-md-6">
    <h3 class="mt-0">{{ name }}</h3>
    <div class="row">
        <label>
            <button type="button" class="w-100" name="select-address"{% if readonly %} disabled style="background: silver; color: gray; opacity: 0.8"{% endif %}>
                Wybierz z książki adresowej
            </button>
        </label>
    </div>
    <div class="row">
        <label>
            Kraj {{ txt1 }}
            <select name="addresses.{{ type }}.country" required="required" {% if readonly%} disabled{% endif %}>
                {% for country in getEuCountries(address.country.iso) %}
                    <option value="{{ country.iso }}"{% if country.selected %} selected {% endif %}>{{ country.name }}</option>
                {% endfor %}
            </select>
            {% if readonly %}
                <input type="hidden" name="addresses.{{ type }}.country" value="{{ address.country.iso }}">
            {% endif %}
        </label>
    </div>
    <div class="row">
        <label class="col-lg">
            Imię {{ txt1 }}
            <input name="addresses.{{ type }}.firstname" type="text" value="{{ address.firstname }}"{% if readonly%} readonly{% endif %}/>
        </label>
        <label class="col-lg">
            Nazwisko {{ txt1 }}
            <input name="addresses.{{ type }}.lastname" type="text" value="{{ address.lastname }}"{% if readonly%} readonly{% endif %}/>
        </label>
    </div>
    <div class="row">
        <label>
            Firma {{ txt1 }}
            <input name="addresses.{{ type }}.company" type="text" value="{{ address.company }}"{% if readonly%} readonly{% endif %}/>
        </label>
    </div>
    <div class="row">
        <label class="col-lg-6">
            Ulica {{ txt1 }}
            <input name="addresses.{{ type }}.street" type="text" value="{{ address.street }}"{% if readonly%} readonly{% endif %}/>
        </label>
        <label class="col-lg-3">
            Numer domu
            <input name="addresses.{{ type }}.building" type="text" value="{{ address.building }}"{% if readonly%} readonly{% endif %}/>
        </label>
        <label class="col-lg-3">
            Numer lokalu
            <input name="addresses.{{ type }}.apartment" type="text" value="{{ address.apartment }}"{% if readonly%} readonly{% endif %}/>
        </label>
    </div>
    <div class="row">
        <label class="col-lg-4">
            Kod pocztowy
            <input name="addresses.{{ type }}.postcode" type="text" value="{{ address.postcode }}"{% if readonly%} readonly{% endif %}/>
        </label>
        <label class="col-lg-8">
            Miasto {{ txt1 }}
            <input name="addresses.{{ type }}.city" type="text" value="{{ address.city }}"{% if readonly%} readonly{% endif %}/>
        </label>
    </div>
    <div class="row">
        <label class="col-lg">
            Telefon {{ txt1 }}
            <input name="addresses.{{ type }}.phone" type="text" value="{{ address.phone }}"{% if readonly%} readonly{% endif %}/>
        </label>
        <label class="col-lg">
            Email {{ txt1 }}
            <input name="addresses.{{ type }}.email" type="text" value="{{ address.email }}"{% if readonly%} readonly{% endif %}/>
        </label>
    </div>
    {% if readonly === false%}
    <div class="row">
        <label class="col-lg">
            <input type="checkbox" name="toaddressbook[]" value="{{ type }}"/>
            Dodaj adres do książki adresowej
        </label>
    </div>
    {% endif %}
</div>
