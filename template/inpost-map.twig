    <script>
        function setInpostDropOffPointFromMap(event)
        {
            pointDetails = prepareInpostPoint('Nadawca', event);
        }
        function setInpostDeliveryPointFromMap(event)
        {
            pointDetails = prepareInpostPoint('Odbiorca', event);
        }

        function prepareInpostPoint(type, e) {
            parent.sform.setPoint.call(parent.sform, {
                code: e.detail.name,
                name: e.detail.address.line1 + ', ' + e.detail.address.line2 + ' (' + e.detail.name + ')'
            });
            return pointDetails;
        }


        document.addEventListener('onpointselect', {% if data.direction == 'nadawca' %}setInpostDropOffPointFromMap{% else %}setInpostDeliveryPointFromMap{% endif %});
    </script>
